# Django backend config. Copy to backend-django.env and fill secrets.
DATABASE_URL=postgres://social:social_dev_password@db:5432/social_django
DJANGO_SECRET_KEY=change-me-django-dev-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=django.localhost,localhost,127.0.0.1,backend-django
JWT_SECRET_KEY=change-me-django-jwt-dev-secret
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7
CODE_TTL_MINUTES=10
ENV=dev
NOTIFIER=console
# Optional real senders (only read when NOTIFIER=smtp / twilio):
# SMTP_HOST=  SMTP_PORT=  SMTP_USER=  SMTP_PASSWORD=  SMTP_FROM=
# TWILIO_ACCOUNT_SID=  TWILIO_AUTH_TOKEN=  TWILIO_FROM=
CORS_ALLOWED_ORIGINS=http://django.localhost
