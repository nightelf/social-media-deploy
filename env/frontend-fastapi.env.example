# Next.js instance wired to the FastAPI backend. Copy to frontend-fastapi.env.
NEXT_PUBLIC_API_BASE_URL=/api                       # browser -> same-origin via nginx (no CORS)
INTERNAL_API_URL=http://backend-fastapi:8000        # SSR -> docker network
NEXT_PUBLIC_BACKEND_LABEL=FastAPI
WATCHPACK_POLLING=true                              # reliable hot reload on mounted volumes
